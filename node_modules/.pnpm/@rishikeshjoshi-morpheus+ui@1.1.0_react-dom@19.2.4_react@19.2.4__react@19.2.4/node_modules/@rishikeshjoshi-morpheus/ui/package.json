{
  "name": "@rishikeshjoshi-morpheus/ui",
  "version": "1.1.0",
  "description": "Reusable UI Components with Chakra UI",
  "author": "OnlineSales.ai",
  "homepage": "https://github.com/onlinesales-ai/shared-ui",
  "license": "ISC",
  "sideEffects": false,
  "main": "dist/src/index.js",
  "module": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "require": "./dist/src/index.js"
    },
    "./tokens.css": "./dist/tokens.css"
  },
  "files": [
    "dist",
    "scripts"
  ],
  "scripts": {
    "build": "tsc --noEmit || true && babel src --out-dir dist/src --extensions '.ts,.tsx' --copy-files && node scripts/generate-tokens.js",
    "build:babel-only": "babel src --out-dir dist/src --extensions '.ts,.tsx' --copy-files && node scripts/generate-tokens.js",
    "generate-tokens": "node scripts/generate-tokens.js",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@chakra-ui/react": "3.33.0",
    "@emotion/react": "11.14.0",
    "next-themes": "0.4.6",
    "react-icons": "5.5.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.0",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.28.0",
    "@types/react": "^18.2.0",
    "typescript": "^5.3.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "ssh://git@github.com:onlinesales-ai/shared-ui.git",
    "directory": "components"
  }
}
